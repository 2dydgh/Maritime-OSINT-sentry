{$DOMAIN:localhost} {
    # Grafana (SERVE_FROM_SUB_PATH=true이므로 prefix 유지)
    handle /grafana/* {
        reverse_proxy grafana:3000
    }

    # Prometheus (운영자만 접근)
    handle /prometheus/* {
        reverse_proxy prometheus:9090
    }

    # 기본 앱
    handle {
        reverse_proxy app:8001
    }

    # 압축
    encode gzip

    # 로그
    log {
        output file /data/access.log
        format json
    }
}
